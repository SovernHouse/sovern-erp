{
  "expo": {
    "name": "Sovern Ops",
    "slug": "sovern-ops",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2E1E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.sovernhouse.ops",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B2E1E"
      },
      "package": "co.sovernhouse.ops",
      "permissions": ["NOTIFICATIONS", "POST_NOTIFICATIONS"]
    },
    "scheme": "sovern-ops",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1D5A32",
          "defaultChannel": "dev-mode"
        }
      ]
    ],
    "newArchEnabled": true,
    "extra": {
      "router": {},
      "eas": {
        "projectId": "76a4e7a2-6585-4212-aa0c-1f8cfe7e001f"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/76a4e7a2-6585-4212-aa0c-1f8cfe7e001f"
    }
  }
}
