FROM node:18-alpine

WORKDIR /app

# Install dependencies
RUN apk add --no-cache python3 make g++

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy application code
COPY . .

# Expose port (dynamically set from environment)
EXPOSE 3000 3001 3002 3003

# Start Vite dev server
CMD ["npm", "run", "dev"]
