# ============================================
# Trading ERP System - Environment Configuration
# ============================================
# Complete guide at: /backend/docs/ENV_GUIDE.md
# Required vars: JWT_SECRET, JWT_REFRESH_SECRET
# Recommended: SMTP_*, REDIS_*, S3_* for full features

# ============================================
# Application Environment
# ============================================
NODE_ENV=development
LOG_LEVEL=debug

# ============================================
# Server Configuration
# ============================================
PORT=3001
API_URL=http://localhost:3001
API_VERSION=v1

# ============================================
# Database Configuration
# ============================================
# Type: sqlite (default, local dev) or postgresql (production)
DB_TYPE=sqlite
SQLITE_PATH=./database.sqlite

# PostgreSQL Configuration (when DB_TYPE=postgresql)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_erp
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_REAPER_INTERVAL=5000
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

# Alternative: Use DATABASE_URL for PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/trading_erp

# ============================================
# Redis Configuration (RECOMMENDED for production)
# ============================================
# Used for caching, sessions, and background jobs
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ============================================
# JWT Authentication (REQUIRED)
# ============================================
# Generate strong secrets in production (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars-required
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# SMTP Email Configuration (RECOMMENDED)
# ============================================
# Required for email notifications, alerts, and reporting
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Trading ERP System
SMTP_FROM_EMAIL=noreply@tradingerp.com
EMAIL_TEMPLATE_DIR=./templates/emails
ENABLE_EMAIL=true

# ============================================
# File Upload Configuration
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,csv,jpg,jpeg,png,gif,zip
STORAGE_TYPE=local

# AWS S3 Configuration (Optional - for production file storage)
S3_REGION=us-east-1
S3_BUCKET=your-bucket-name
S3_KEY=your-aws-access-key
S3_SECRET=your-aws-secret-key

# ============================================
# Portal URLs
# ============================================
ADMIN_URL=http://localhost:3000
CUSTOMER_URL=http://localhost:3002
FACTORY_URL=http://localhost:3003
CUSTOMER_MOBILE_URL=https://mobile-customer.tradingerp.com
FACTORY_MOBILE_URL=https://mobile-factory.tradingerp.com

# ============================================
# CORS & Security Configuration
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3002,http://localhost:3003
CORS_CREDENTIALS=true
SOCKET_IO_CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# ============================================
# Pagination
# ============================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================
# Logging
# ============================================
LOG_FORMAT=json
LOG_DIR=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# ============================================
# Security
# ============================================
BCRYPT_ROUNDS=10
SESSION_SECRET=your-session-secret-change-in-production
SESSION_MAX_AGE=86400000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Company Information
# ============================================
COMPANY_NAME=Trading Company LLC
COMPANY_LOGO_URL=https://example.com/logo.png
COMPANY_ADDRESS=123 Trade Street, Commerce City
COMPANY_PHONE=+1-555-0100
COMPANY_EMAIL=info@tradingerp.com
COMPANY_WEBSITE=https://tradingerp.com

# ============================================
# Tax Configuration
# ============================================
DEFAULT_TAX_RATE=0.10
TAX_CURRENCY=USD

# ============================================
# Document Configuration
# ============================================
ENABLE_PDF_GENERATION=true
PDF_GENERATOR=puppeteer
DOCUMENT_TEMPLATE_DIR=./templates/documents
ENABLE_DIGITAL_SIGNATURE=false

# ============================================
# SMS Configuration (Optional)
# ============================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================
# Notification Configuration
# ============================================
ENABLE_NOTIFICATIONS=true
NOTIFICATION_QUEUE=redis
WEBHOOK_TIMEOUT=30000

# ============================================
# API Rate Limiting by Endpoint
# ============================================
RATE_LIMIT_AUTH=5/m
RATE_LIMIT_API=100/m
RATE_LIMIT_UPLOAD=10/m

# ============================================
# Third-party Integrations
# ============================================
ENABLE_STRIPE=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

ENABLE_SHOPIFY=false
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ============================================
# Blockchain/Smart Contracts (Optional)
# ============================================
ENABLE_BLOCKCHAIN=false
BLOCKCHAIN_PROVIDER=
BLOCKCHAIN_CONTRACT_ADDRESS=

# ============================================
# Analytics
# ============================================
ENABLE_ANALYTICS=true
ANALYTICS_PROVIDER=mixpanel
MIXPANEL_TOKEN=

# ============================================
# Error Tracking
# ============================================
ENABLE_ERROR_TRACKING=true
SENTRY_DSN=

# ============================================
# Backup Configuration
# ============================================
ENABLE_AUTO_BACKUP=true
ENABLE_SCHEDULED_BACKUP=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_DIR=./backups

# ============================================
# Scheduler Configuration
# ============================================
ENABLE_EXCHANGE_RATE_SCHEDULER=true
EXCHANGE_RATE_SCHEDULE=0 0 * * MON

# Background job scheduler (node-cron) — set to 'false' to disable individual jobs
SCHEDULER_ACTIVITY_REMINDERS=true
SCHEDULER_FOLLOWUP_REMINDERS=true
SCHEDULER_INVOICE_OVERDUE=true
SCHEDULER_PRODUCTION_ALERTS=true
SCHEDULER_DATA_RETENTION=true

# Production delay threshold (days before alerting)
PRODUCTION_ALERT_DAYS=45

# Data retention: hard-delete soft-deleted records older than this many days (GDPR / right-to-erasure)
DATA_RETENTION_DAYS=365

# ============================================
# Module Flags (enable/disable features)
# ============================================
MODULE_COMPLIANCE_ENABLED=true
MODULE_WAREHOUSE_ENABLED=true
MODULE_TRADE_FINANCE_ENABLED=true
MODULE_SAMPLE_MANAGEMENT_ENABLED=true
MODULE_LANDED_COST_ENABLED=true

# Feature Flags
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_BULK_OPERATIONS=true
FEATURE_API_WEBHOOKS=true
FEATURE_CUSTOM_REPORTS=true
FEATURE_AUDIT_LOG=true
FEATURE_MULTI_CURRENCY=true
FEATURE_MULTI_LANGUAGE=true
FEATURE_DARK_MODE=true

# ============================================
# UI Configuration
# ============================================
THEME_PRIMARY_COLOR=#1976D2
THEME_SECONDARY_COLOR=#DC004E
THEME_ACCENT_COLOR=#FF6F00
ENABLE_DARK_MODE=true
ITEMS_PER_PAGE_DEFAULT=20

# ============================================
# Performance
# ============================================
ENABLE_CACHING=true
CACHE_TTL=3600
ENABLE_COMPRESSION=true
ENABLE_QUERY_OPTIMIZATION=true
MAX_CONCURRENT_REQUESTS=50

# ============================================
# Audit & Compliance
# ============================================
ENABLE_AUDIT_LOG=true
AUDIT_LOG_RETENTION_DAYS=365
GDPR_COMPLIANCE=true
DATA_RETENTION_POLICY=7y

# ============================================
# Development Only
# ============================================
DEBUG=trading-erp:*
MOCK_EXTERNAL_SERVICES=false
SEED_DATABASE=false
SEED_DATA_FILE=./seeds/sample-data.json
