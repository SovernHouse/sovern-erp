# ─────────────────────────────────────────────────────────────
# Admin Portal — Tenant / White-label Configuration
# Copy this file to .env and fill in values for your deployment.
# All VITE_ variables are embedded at build time by Vite.
# ─────────────────────────────────────────────────────────────

# ── API endpoints ────────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000

# ── Company identity ─────────────────────────────────────────
VITE_COMPANY_NAME=Sovern House
VITE_COMPANY_DOMAIN=sovernhouse.co
VITE_ADMIN_EMAIL=admin@sovernhouse.co

# ── Branding ─────────────────────────────────────────────────
# Primary logo — shown in email previews, PDF exports, and white-label layouts.
VITE_LOGO_URL=https://sovernhouse.co/logos/sovern-wordmark-email-light.png
# Primary brand accent colour (hex) — buttons, active nav, links.
VITE_BRAND_COLOR=#1D5A32
# Contrast text colour used on brand-color backgrounds.
VITE_BRAND_CONTRAST=#F1EEE7

# ── Feature flags ────────────────────────────────────────────
# Set to "false" to hide entire feature areas for this tenant.
VITE_ENABLE_CRM=true
VITE_ENABLE_OUTREACH=true
