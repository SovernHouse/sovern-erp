# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_erp
DB_USER=postgres
DB_PASSWORD=your_password

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRY=30d

# Server Configuration
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@tradingErp.com

# File Upload Configuration
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx,xls,xlsx

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Socket.IO Configuration
SOCKET_IO_PORT=5001
SOCKET_IO_CORS_ORIGIN=http://localhost:3000

# PDF Configuration
PDF_AUTHOR=Trading ERP System
PDF_COMPANY_NAME=Global Flooring Trading Co.
PDF_COMPANY_ADDRESS=123 Trading Street, Commerce City
PDF_COMPANY_PHONE=+1-800-TRADING
PDF_COMPANY_EMAIL=info@tradingErp.com

# Document Number Prefixes
DOC_PREFIX_INQUIRY=INQ
DOC_PREFIX_QUOTATION=QOT
DOC_PREFIX_PI=PI
DOC_PREFIX_SO=SO
DOC_PREFIX_PO=PO
DOC_PREFIX_PL=PL
DOC_PREFIX_SHIPMENT=SHP
DOC_PREFIX_INSPECTION=INSP
DOC_PREFIX_CLAIM=CLM
DOC_PREFIX_INVOICE=INV

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SOCKET_IO=true
ENABLE_PDF_GENERATION=true
