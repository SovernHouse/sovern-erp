# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_erp
DB_USER=postgres
DB_PASSWORD=your_password

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRY=30d

# Server Configuration
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@tradingErp.com

# File Upload Configuration
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx,xls,xlsx

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Socket.IO Configuration
SOCKET_IO_PORT=5001
SOCKET_IO_CORS_ORIGIN=http://localhost:3000

# PDF Configuration
PDF_AUTHOR=Trading ERP System
PDF_COMPANY_NAME=Global Flooring Trading Co.
PDF_COMPANY_ADDRESS=123 Trading Street, Commerce City
PDF_COMPANY_PHONE=+1-800-TRADING
PDF_COMPANY_EMAIL=info@tradingErp.com

# Document Number Prefixes
DOC_PREFIX_INQUIRY=INQ
DOC_PREFIX_QUOTATION=QOT
DOC_PREFIX_PI=PI
DOC_PREFIX_SO=SO
DOC_PREFIX_PO=PO
DOC_PREFIX_PL=PL
DOC_PREFIX_SHIPMENT=SHP
DOC_PREFIX_INSPECTION=INSP
DOC_PREFIX_CLAIM=CLM
DOC_PREFIX_INVOICE=INV

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SOCKET_IO=true
ENABLE_PDF_GENERATION=true

# ─────────────────────────────────────────────────────────────
# Tenant / White-label Configuration
# ─────────────────────────────────────────────────────────────
COMPANY_NAME=Sovern House
COMPANY_DOMAIN=sovernhouse.co
ADMIN_EMAIL=admin@sovernhouse.co
# Comma-separated list of sending domains allowed by outreachController
ALLOWED_SENDING_DOMAINS=sovernhouse.co,sovern-house.com

# ─────────────────────────────────────────────────────────────
# Sentry Error Tracking (production observability)
# ─────────────────────────────────────────────────────────────
# DSN for the sovern-erp-backend project. Leave blank in local dev unless
# you specifically want to send local errors to Sentry. Setting this in
# production enables automatic error capture and Express auto-instrumentation.
SENTRY_DSN=https://1036c760a04cc1a464b7f3eb078255b2@o4511312573693952.ingest.de.sentry.io/4511312697294928
# Optional: release identifier for source-map and release tracking. Typically
# set in CI to the git SHA, e.g. SENTRY_RELEASE=$(git rev-parse --short HEAD)
SENTRY_RELEASE=
# Force-enable Sentry events from local development. Default: only enabled in
# NODE_ENV=production. Set to "true" to send dev errors to Sentry for testing.
SENTRY_FORCE_ENABLE=false

# ─────────────────────────────────────────────────────────────
# Dev Mode (super_admin only — sandboxed AI code-change runs)
# ─────────────────────────────────────────────────────────────
# Path to the live ERP repo on disk. Defaults to the repo root resolved
# from backend/. Override only if the repo lives somewhere unusual.
# DEV_MODE_REPO_PATH=/home/alex/sovern-erp
# Where per-run worktrees are created. Defaults to <repo>-dev-runs sibling.
# DEV_MODE_WORKTREE_BASE=/home/alex/sovern-erp-dev-runs
# Git identity for dev-mode commits (must match the GitHub account that
# Vercel/CI is set up for, per L-032).
DEV_MODE_GIT_NAME=VendettaGamesHQ
DEV_MODE_GIT_EMAIL=thevendettadao@gmail.com
# Base branch for PRs.
DEV_MODE_PR_BASE=main

# ─────────────────────────────────────────────────────────────
# Resend (email summaries from dev-mode)
# ─────────────────────────────────────────────────────────────
# RESEND_API_KEY is already set elsewhere if email is configured. The
# dev-mode notifier will silently skip email if RESEND_API_KEY is unset.
# RESEND_API_KEY=
# Sender for dev-mode summary emails. Defaults to "Sovern ERP <noreply@sovernhouse.co>".
# RESEND_FROM_ADDRESS=Sovern ERP <noreply@sovernhouse.co>

# ─────────────────────────────────────────────────────────────
# Expo Push (mobile dev-mode notifications)
# ─────────────────────────────────────────────────────────────
# Optional bearer token for Expo push API (raises rate limits, allows
# enhanced security). Without it, pushes still work but with default
# anonymous rate limits.
# EXPO_ACCESS_TOKEN=
